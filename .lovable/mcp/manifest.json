{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "facility-finder-mcp",
      "version": "0.1.0",
      "title": "Facility Finder MCP"
    },
    "tools": [
      {
        "name": "list_offices",
        "title": "List offices and regions",
        "description": "List all regions and their area offices. Use the returned office_id / region_id values to filter facilities, payments, and permitted applications.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "search_facilities",
        "title": "Search facilities",
        "description": "Search facility permit records. Filter by name (partial, case-insensitive), sector, district, region_id, or office_id. Returns up to `limit` rows (default 25, max 200).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Partial facility name match."
            },
            "sector": {
              "type": "string",
              "minLength": 1
            },
            "district": {
              "type": "string",
              "minLength": 1
            },
            "region_id": {
              "type": "string",
              "format": "uuid"
            },
            "office_id": {
              "type": "string",
              "format": "uuid"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "search_payments",
        "title": "Search payments",
        "description": "Search payment records. Filter by payer name (partial), sector, category, region_id, office_id, or date range (payment_date between from/to, YYYY-MM-DD). Returns up to `limit` rows (default 25, max 200) plus a total_amount sum for the matched rows.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "sector": {
              "type": "string",
              "minLength": 1
            },
            "category": {
              "type": "string",
              "minLength": 1
            },
            "region_id": {
              "type": "string",
              "format": "uuid"
            },
            "office_id": {
              "type": "string",
              "format": "uuid"
            },
            "from": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "to": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "search_permitted_applications",
        "title": "Search permitted applications",
        "description": "Search permitted-application records. Filter by facility name (partial), sector, district, region_id, or office_id. Returns up to `limit` rows (default 25, max 200).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "sector": {
              "type": "string",
              "minLength": 1
            },
            "district": {
              "type": "string",
              "minLength": 1
            },
            "region_id": {
              "type": "string",
              "format": "uuid"
            },
            "office_id": {
              "type": "string",
              "format": "uuid"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
